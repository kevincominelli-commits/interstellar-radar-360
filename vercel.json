{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/radar-search.js": {
      "maxDuration": 60
    },
    "api/radar-admin.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
